{
  "rules": {
    "zones": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && auth.token.email.contains('control')"
    },
    "staff": {
      ".read": "auth != null",
      "$staffId": {
        ".write": "auth != null && auth.token.email != null && auth.token.email.contains('staff')"
      }
    },
    "attendees": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "instructions": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && auth.token.email.contains('control')",
      "$instructionId": {
        "acknowledgedBy": {
          "$ackId": {
            ".write": "auth != null"
          }
        }
      }
    },
    "nudges": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && auth.token.email.contains('control')"
    },
    "feedback": {
      ".write": "auth != null",
      ".read": "auth != null && auth.token.email != null && auth.token.email.contains('control')"
    },
    "reports": {
      ".write": "auth != null",
      ".read": "auth != null && auth.token.email != null && auth.token.email.contains('control')"
    }
  }
}
